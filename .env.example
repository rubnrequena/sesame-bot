# Copia este archivo como .env y completa los valores
# cp .env.example .env

# ── Base de datos PostgreSQL (requerido) ──────────────────────────────────────
DATABASE_URL=postgres://sesame:secret@localhost:5432/sesame_bot?sslmode=disable

# ── Cifrado AES-256-GCM para contraseñas de Sesame guardadas en DB ────────────
# Genera con: openssl rand -hex 32
# Si no se define, los usuarios solo podrán usar la opción "solo en memoria"
ENCRYPTION_KEY=pon_aqui_64_hex_chars

# ── Servidor web ──────────────────────────────────────────────────────────────
ADMIN_PORT=8080

# ── Zona horaria ──────────────────────────────────────────────────────────────
# TZ=Europe/Madrid
