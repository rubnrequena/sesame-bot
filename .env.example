# Copia este archivo como .env y completa tus credenciales
# cp .env.example .env

SESAME_EMAIL=tu_email@empresa.com
SESAME_PASSWORD=tu_contraseña_aqui

# Modo headless: true = sin ventana (producción) | false = ventana visible (debug)
HEADLESS=true

# ── Horario genérico (aplica a todos los días sin override específico) ─────────
# Horas de entrada separadas por coma (formato HH:MM, 24h)
HOURS_IN=09:00

# Horas de salida separadas por coma (formato HH:MM, 24h)
HOURS_OUT=18:00

# ── Fin de semana ──────────────────────────────────────────────────────────────
# true  = ejecutar también sábado y domingo
# false = omitir fin de semana (recomendado)
WEEKEND=false

# ── Overrides por día (opcional) ───────────────────────────────────────────────
# Si se define un override para un día, reemplaza el horario genérico ese día.
# Días disponibles: SUNDAY, MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY

# Ejemplo: el viernes se trabaja de 09:00 a 15:00
FRIDAY_IN=09:00
FRIDAY_OUT=15:00

# Ejemplo: el miércoles hay dos turnos de entrada
# WEDNESDAY_IN=09:00,14:00
# WEDNESDAY_OUT=13:00,18:00

# ── Geolocalización ────────────────────────────────────────────────────────────
# Coordenadas en formato: latitud,longitud
LOCATION_OFFICE=40.416775,-3.703790
LOCATION_HOME=40.123456,-3.456789

# Días que se va a la oficina (usa LOCATION_OFFICE); el resto usa LOCATION_HOME
# Separar por coma
OFFICE_DAYS=Tuesday,Thursday

# ── Admin Web UI ──────────────────────────────────────────────────────────────
# Puerto del servidor de administración (por defecto: 8080)
ADMIN_PORT=8080

# Contraseña para acceder a la UI de configuración
ADMIN_PASSWORD=cambia_esta_contraseña
